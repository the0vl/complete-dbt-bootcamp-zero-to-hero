{
  "python.defaultInterpreterPath": "./.venv/bin/python",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "YAML keys",
        "scope": [
          "entity.name.tag.yaml",
          "meta.mapping.key.yaml"
        ],
        "settings": {
          "foreground": "#4EA1FF"
        }
      },
      {
        "name": "YAML values",
        "scope": [
          "string.unquoted.yaml",
          "string.quoted.single.yaml",
          "string.quoted.double.yaml"
        ],
        "settings": {
          "foreground": "#FF9D3F"
        }
      }
    ]
  }
}
